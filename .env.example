# --- Backend (FastAPI) ---
# Host port exposed for the API (container always listens on 8000 internally).
BACKEND_PORT=8000

# --- Lichess opening explorer ---
# The opening explorer now requires authentication. Generate a free personal
# API token at https://lichess.org/account/oauth/token (no scope required) and
# paste it here. Without it, /api/v1/moves/{fen} returns an explicit 502 error.
LICHESS_TOKEN=
